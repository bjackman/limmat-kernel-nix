# Stuff to make debugging easier. These options work on every arch; options
# that we only enable on 64-bit builds live in the debug/64bit fragment.
# Note there is also a debug.config in the kernel source, you can just run `make
# debug.config`. That enables almost everything including KASAN, this is a much
# more lightweight option.
CONFIG_DEBUG_KERNEL=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_GDB_SCRIPTS=y
CONFIG_DEBUG_LIST=y
# CONFIG_RANDOMIZE_BASE is not set

CONFIG_DEBUG_VIRTUAL=y
CONFIG_DEBUG_VM=y
CONFIG_DEBUG_VM_PGFLAGS=y

CONFIG_DEBUG_ATOMIC_SLEEP=y
CONFIG_DETECT_HUNG_TASK=y
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_TIMEOUT=0
CONFIG_SOFTLOCKUP_DETECTOR=y

CONFIG_PROVE_LOCKING=y
